---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

import { Paginator, PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import {
  blogCategories,
  getBlogCategoryLabel
} from '../../../data/blog-categories'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

export const prerender = true

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPostsByDate = sortMDByDate(
    (await getBlogCollection()) as CollectionEntry<'blog'>[]
  ) as CollectionEntry<'blog'>[]

  return blogCategories.flatMap((category) => {
    const filterPosts = allPostsByDate.filter((post) => post.data.category === category.slug)

    if (filterPosts.length === 0) {
      return [
        {
          params: { category: category.slug, page: undefined },
          props: {
            page: {
              currentPage: 1,
              data: [],
              end: 0,
              lastPage: 1,
              size: 0,
              start: 0,
              total: 0,
              url: {
                current: `/categories/${category.slug}`,
                first: `/categories/${category.slug}`,
                last: `/categories/${category.slug}`,
                next: undefined,
                prev: undefined
              }
            } satisfies Page<CollectionEntry<'blog'>>,
            categoryLabel: category.label
          }
        }
      ]
    }

    return paginate(filterPosts, {
      pageSize: config.content.blogPageSize,
      params: { category: category.slug },
      props: { categoryLabel: category.label }
    })
  })
}

interface Props {
  page: Page<CollectionEntry<'blog'>>
  categoryLabel: string
}

const { page, categoryLabel } = Astro.props
const { category } = Astro.params

const resolvedCategoryLabel = categoryLabel || getBlogCategoryLabel(String(category ?? ''))

const meta = {
  description: `View all posts in the ${resolvedCategoryLabel} category`,
  title: `Category: ${resolvedCategoryLabel}`
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: `← Previous Category Posts`,
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: `Next Category Posts →`,
      url: page.url.next
    }
  })
}
---

<PageLayout {meta}>
  <Button title='Back' href='/categories' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-2 text-3xl font-medium'>{resolvedCategoryLabel}</h1>
      <p class='text-sm text-muted-foreground'>{category}</p>
    </div>

    <section id='content' class='animate mt-6' aria-label='Category post list'>
      {
        page.data.length === 0 ? (
          <p class='text-muted-foreground'>這個分類目前還沒有文章。</p>
        ) : (
          <>
            <div class='mb-3 text-sm sm:mb-5'>
              <span class='text-muted-foreground'>
                Page {page.currentPage} - Showing {page.data.length} posts in {resolvedCategoryLabel}
              </span>
            </div>
            <ul class='flex flex-col gap-y-4 text-start'>
              {page.data.map((post) => (
                <PostPreview
                  {post}
                  detailed
                  categoryLabel={resolvedCategoryLabel}
                  categoryHref={`/categories/${post.data.category}`}
                />
              ))}
            </ul>
            <Paginator {...paginationProps} />
          </>
        )
      }
    </section>
  </main>
</PageLayout>
